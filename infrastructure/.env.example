# ===========================================
# Django Platform — richardnixon.dev
# ===========================================
PLATFORM_DB_NAME=platform
PLATFORM_DB_USER=platform
PLATFORM_DB_PASSWORD=your_platform_db_password

# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your_django_secret_key

# Optional: auto-create superuser on first run
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Sentry error tracking (optional) — get DSN from https://sentry.io/
SENTRY_DSN=

# reCAPTCHA v3 — get from https://www.google.com/recaptcha/admin
RECAPTCHA_PUBLIC_KEY=your_recaptcha_public_key
RECAPTCHA_PRIVATE_KEY=your_recaptcha_private_key

# Social Auth (configure providers in Django admin after setup)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ===========================================
# LocFlow — locflow.richardnixon.dev
# ===========================================
LOCFLOW_DB_NAME=locflow
LOCFLOW_DB_USER=locflow
LOCFLOW_DB_PASSWORD=your_locflow_db_password
LOCFLOW_SECRET_KEY=your_locflow_secret_key
LOCFLOW_SUPERUSER_EMAIL=
LOCFLOW_SUPERUSER_PASSWORD=
LOCFLOW_UMAMI_WEBSITE_ID=

# ===========================================
# EireScope — osint.richardnixon.dev
# ===========================================
EIRESCOPE_SECRET_KEY=your_eirescope_secret_key

# ===========================================
# WordPress — richardemanu.com
# ===========================================
MYSQL_ROOT_PASSWORD=your_mysql_root_password
WP_DB_PASSWORD=your_wordpress_db_password

# ===========================================
# Monitoring (Grafana, Prometheus, Loki)
# ===========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password

# ===========================================
# Umami Analytics
# ===========================================
UMAMI_DB_PASSWORD=your_umami_db_password
UMAMI_APP_SECRET=your_umami_app_secret
# Get website ID from Umami dashboard after creating a website
UMAMI_WEBSITE_ID=

# ===========================================
# CrowdSec (Security/IPS)
# ===========================================
# Generate bouncer key: docker compose exec crowdsec cscli bouncers add traefik-bouncer
CROWDSEC_BOUNCER_KEY=

# ===========================================
# Authentik — SSO/2FA Identity Provider
# ===========================================
# Generate: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=your_authentik_secret_key
AUTHENTIK_DB_PASSWORD=your_authentik_db_password
AUTHENTIK_BOOTSTRAP_PASSWORD=your_authentik_bootstrap_password
AUTHENTIK_BOOTSTRAP_EMAIL=your_email@example.com

# ===========================================
# Valheim Server
# ===========================================
VALHEIM_PASSWORD=your_valheim_password

# ===========================================
# Forgejo — git.richardnixon.dev
# ===========================================
FORGEJO_DB_PASSWORD=your_forgejo_db_password
# Generate: openssl rand -base64 48 | tr -d '\n'
FORGEJO_SECRET_KEY=your_forgejo_secret_key
# Generate: openssl rand -base64 64 | tr -d '\n'
FORGEJO_INTERNAL_TOKEN=your_forgejo_internal_token
# Generate: openssl rand -base64 32 | tr -d '=' | tr '+/' '-_'
FORGEJO_OAUTH2_JWT_SECRET=your_forgejo_oauth2_jwt_secret
# Populate after creating Application+Provider in Authentik admin
FORGEJO_OIDC_CLIENT_ID=
FORGEJO_OIDC_CLIENT_SECRET=
